    "Headless single-scene load with full pipeline tracing. Every shader compile error, FBO miss, first-frame snapshot lands under scene-debug as `<timestamp>-<workshopID>/`." : {
      "comment" : "Developer tools description for the single-scene debug section.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Headless single-scene load with full pipeline tracing. Every shader compile error, FBO miss, first-frame snapshot lands under scene-debug as `<timestamp>-<workshopID>/`."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヘッドレスで単一シーンを読み込み、パイプライン全体をトレースします。シェーダーコンパイルエラー、FBO ミス、最初のフレームのスナップショットがすべて scene-debug の `<timestamp>-<workshopID>/` に書き出されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无界面单场景加载，全流水线追踪。所有 shader 编译错误、FBO 未命中、首帧快照都会落到 scene-debug 下的 `<timestamp>-<workshopID>/`。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
