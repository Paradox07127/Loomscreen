    "Apple Aerials access was denied. Grant access in System Settings → Privacy & Security, or pick another source." : {
      "comment" : "Inline error shown in onboarding when the user denies Apple Aerials access.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Aerials access was denied. Grant access in System Settings → Privacy & Security, or pick another source."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Aerials へのアクセスが拒否されました。「システム設定」→「プライバシーとセキュリティ」でアクセスを許可するか、別のソースを選択してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Aerials 访问被拒绝。请在“系统设置”→“隐私与安全性”中授权，或选择其他来源。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Aerials 存取遭拒。請在「系統設定」→「隱私權與安全性」中允許存取，或選擇其他來源。"
          }
        }
      }
    },
    "Apple downloads aerial wallpapers on demand. Pick one from System Settings → Wallpaper, then refresh." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple downloads aerial wallpapers on demand. Pick one from System Settings → Wallpaper, then refresh."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple は必要に応じて空撮壁紙をダウンロードします。「システム設定」→「壁紙」で選択してから、更新してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple 按需下载动态壁纸。从“系统设置” → “壁纸”中选择一个，然后刷新。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple 會視需要下載航拍桌布。請先在「系統設定」→「桌布」中選擇一個，然後重新整理。"
          }
        }
      }
    },
