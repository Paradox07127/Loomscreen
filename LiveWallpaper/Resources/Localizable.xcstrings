      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャプチャスクリプトとそのデータファイルを削除します。settings.json に statusLine ブロックを追加していた場合は、その後元の statusLine に戻してください。"
