    },
    "This wallpaper uses a `.tex` container we don't decode yet (%@). Phase 2.x will keep widening coverage as new versions appear." : {
      "comment" : "Wallpaper Engine fallback warning body. The placeholder is a texture container magic value.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This wallpaper uses a `.tex` container we don't decode yet (%@). Phase 2.x will keep widening coverage as new versions appear."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この壁紙は、まだデコードしていない `.tex` コンテナ（%@）を使用しています。Phase 2.x は新しいバージョンにあわせて対応範囲を拡大していきます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此壁纸使用了尚未解码的 `.tex` 容器（%@）。Phase 2.x 会随着新版本继续扩大支持范围。"
          }
