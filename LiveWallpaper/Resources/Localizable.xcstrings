          }
        }
      }
    },
    "This lets you click elements inside the scene, but while it's on you can't click desktop icons or right-click the desktop on this display. Turn it off here to restore desktop clicks." : {
      "comment" : "A message that appears when the user enables",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シーン内の要素をクリックできるようになりますが、オンの間はこのディスプレイでデスクトップアイコンをクリックしたり、デスクトップを右クリックしたりできません。デスクトップクリックを戻すにはここでオフにしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这允许你点击场景内元素，但开启时无法点击此显示器上的桌面图标，也无法右键点击桌面。在这里关闭即可恢复桌面点击。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這允許你點按場景內元素，但開啟時無法點按此顯示器上的桌面圖示，也無法右鍵點按桌面。在這裡關閉即可恢復桌面點按。"
          }
        }
      }
    },
    "This scene needs rendering features that are not supported on Mac yet. We're working on broader Phase 2 support — your other wallpapers continue to play unaffected." : {
      "comment" : "Scene fallback warning body.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This scene needs rendering features that are not supported on Mac yet. We're working on broader Phase 2 support — your other wallpapers continue to play unaffected."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このシーンの再生には、Mac ではまだ対応していないレンダリング機能が必要です。Phase 2 の対応範囲を拡大中です。他の壁紙は影響を受けずに再生されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此场景需要 Mac 暂不支持的渲染功能。我们正在扩展 Phase 2 支持，其他壁纸会继续正常播放。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此場景需要 Mac 尚未支援的算繪功能。我們正在擴充 Phase 2 支援；其他桌布會照常播放，不受影響。"
          }
        }
      }
    },
    "This scene uses a custom shader the renderer couldn't translate to Metal. Try re-downloading the project in Steam." : {
      "comment" : "Wallpaper Engine fallback warning body.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This scene uses a custom shader the renderer couldn't translate to Metal. Try re-downloading the project in Steam."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このシーンは、レンダラーが Metal に変換できないカスタムシェーダーを使用しています。Steam でプロジェクトを再ダウンロードしてみてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此场景使用了渲染器无法转译为 Metal 的自定义着色器。请尝试在 Steam 中重新下载该项目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此場景使用了渲染器無法轉譯為 Metal 的自訂著色器。請嘗試在 Steam 中重新下載此專案。"
          }
        }
      }
    },
    "This Steam account can't download Wallpaper Engine items — it may not own Wallpaper Engine, or downloads are region-restricted." : {
      "comment" : "Workshop download blocked: account not entitled.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この Steam アカウントでは Wallpaper Engine アイテムをダウンロードできません — Wallpaper Engine を所有していないか、地域制限がある可能性があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此 Steam 账户无法下载 Wallpaper Engine 项目 — 可能未拥有 Wallpaper Engine，或下载受到地区限制。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此 Steam 帳戶無法下載 Wallpaper Engine 項目 — 可能未擁有 Wallpaper Engine，或下載受到地區限制。"
          }
        }
      }
    },
    "This Steam account doesn't own Wallpaper Engine, so its assets can't be downloaded." : {
      "comment" : "Engine-assets download blocked: account doesn't own Wallpaper Engine.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この Steam アカウントは Wallpaper Engine を所有していないため、アセットをダウンロードできません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此 Steam 账号未拥有 Wallpaper Engine,无法下载其资源。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此 Steam 帳號未擁有 Wallpaper Engine,無法下載其資源。"
          }
        }
      }
    },
    "This wallpaper bundles a Windows `.dll` plugin (e.g. an audio visualizer or screensaver runtime). macOS can't load Windows native code, so the project is permanently unsupported here." : {
      "comment" : "Wallpaper Engine fallback warning body.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This wallpaper bundles a Windows `.dll` plugin (e.g. an audio visualizer or screensaver runtime). macOS can't load Windows native code, so the project is permanently unsupported here."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この壁紙には Windows の `.dll` プラグイン（オーディオビジュアライザーやスクリーンセーバーランタイムなど）が含まれています。macOS は Windows ネイティブコードを読み込めないため、このプロジェクトはここでは永続的に非対応です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此壁纸捆绑了 Windows `.dll` 插件（例如音频可视化器或屏保运行时）。macOS 无法加载 Windows 原生代码，因此此项目在这里无法支持。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此桌布包含 Windows `.dll` 外掛程式（例如音訊視覺化工具或螢幕保護程式執行階段）。macOS 無法載入 Windows 原生程式碼，因此此專案在此永久不受支援。"
          }
        }
      }
    },
    "This wallpaper is tagged Mature and may contain explicit adult content. By revealing it you confirm you are at least 18 years old, or of legal age in your region." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この壁紙は成人向けタグ付きで、露骨な成人向けコンテンツを含む場合があります。表示すると、18歳以上または地域の法定年齢に達していることを確認したものとみなされます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此壁纸标记为成人内容，可能包含明确的成人内容。显示它即表示你确认自己已满 18 岁，或已达到所在地区的法定年龄。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此桌布標記為成人內容，可能包含明確的成人內容。顯示它即表示你確認自己已年滿 18 歲，或已達所在地區的法定年齡。"
          }
        }
      }
    },
    "This wallpaper relies on other Workshop projects we don't have on disk yet. Subscribe to them in Steam, then re-import this folder." : {
      "comment" : "Wallpaper Engine fallback warning body.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This wallpaper relies on other Workshop projects we don't have on disk yet. Subscribe to them in Steam, then re-import this folder."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この壁紙は、まだディスク上にない他のワークショッププロジェクトに依存しています。Steam でそれらをサブスクライブしてから、このフォルダを再インポートしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
