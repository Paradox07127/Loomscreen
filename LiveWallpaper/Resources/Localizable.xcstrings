    "The bundle includes all global preferences, the wallpaper library bookmarks, and the per-display playback / effect setup. Wallpaper files themselves are not copied — only references to them." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The bundle includes all global preferences, the wallpaper library bookmarks, and the per-display playback / effect setup. Wallpaper files themselves are not copied — only references to them."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バンドルにはすべてのグローバル設定、壁紙ライブラリのブックマーク、ディスプレイごとの再生 / エフェクト設定が含まれます。壁紙ファイル自体はコピーされず、参照のみが保存されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "备份包含所有全局首选项、壁纸库书签和每个显示器的播放/特效设置。壁纸文件本身不会被复制——只保存它们的引用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "備份包含所有全域偏好設定、桌布庫書籤和各顯示器的播放／特效設定。桌布檔案本身不會被複製——僅保存它們的參照。"
          }
        }
      }
    },
