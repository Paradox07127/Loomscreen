    },
    "This scene relies on custom shaders that the image-only Phase 2.0 renderer can't compile yet." : {
      "comment" : "Wallpaper Engine fallback warning body.",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This scene relies on custom shaders that the image-only Phase 2.0 renderer can't compile yet."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此场景依赖自定义着色器，当前仅图像的 Phase 2.0 渲染器尚无法编译。"
          }
        }
      }
    },
    "This scene uses a custom shader the renderer couldn't translate to Metal. Try re-downloading the project in Steam." : {
      "comment" : "Wallpaper Engine fallback warning body.",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此场景使用了渲染器无法转译为 Metal 的自定义着色器。请尝试在 Steam 中重新下载该项目。"
          }
        }
      }
    },
    "This URL uses HTTP. Content cannot be verified — prefer HTTPS when possible." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This URL uses HTTP. Content cannot be verified — prefer HTTPS when possible."
