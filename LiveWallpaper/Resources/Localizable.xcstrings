    },
    "“%@” will be removed from your library and its downloaded files moved to the Trash. You can restore them from the Trash if needed." : {
      "comment" : "A confirmation dialog message for a wallpaper that has files that can be permanently deleted.",
      "isCommentAutoGenerated" : true
    },
    "“%@” will be removed from your library. Its original files (imported from your own folder) are left untouched." : {
      "comment" : "A confirmation dialog message for removing a wallpaper from the library. The argument is the name of the wallpaper.",
      "isCommentAutoGenerated" : true
    },
    "[Get a key](https://steamcommunity.com/dev/apikey)  ·  [Steam Web API TOU](https://steamcommunity.com/dev/apiterms)  ·  [About Limited Accounts](https://help.steampowered.com/en/faqs/view/71D3-35C2-AD96-AA3A)" : {
      "comment" : "A link to Steam's API documentation.",
      "isCommentAutoGenerated" : true
    },
