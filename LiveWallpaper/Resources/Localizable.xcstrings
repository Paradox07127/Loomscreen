    },
    "This allows the wallpaper to run scripts, use local storage, and access WebGPU. Only trust origins you recognize." : {
      "comment" : "Body text of the Trust confirmation dialog.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This allows the wallpaper to run scripts, use local storage, and access WebGPU. Only trust origins you recognize."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "壁紙がスクリプトの実行、ローカルストレージの使用、WebGPU へのアクセスを行えるようになります。信頼できるオリジンのみを許可してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将允许壁纸运行脚本、使用本地存储和访问 WebGPU。仅信任你信赖的来源。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將允許桌布執行腳本、使用本機儲存空間並存取 WebGPU。只信任你信賴的來源。"
          }
        }
      }
    },
    "This clears the cached Steam session on this Mac. You'll sign in again in Terminal to download. To sign out everywhere, deauthorize this device in Steam → Settings → Security." : {
      "comment" : "Sign-out confirmation message.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この Mac にキャッシュされた Steam セッションをクリアします。ダウンロードするにはターミナルで再度サインインしてください。すべての端末からサインアウトするには、Steam →設定→セキュリティでこの端末の認証を解除してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会清除该 Mac 上缓存的 Steam 会话。下载前需在终端重新登录。若要在所有设备上登出,请在 Steam →设置→安全 中取消此设备的授权。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會清除此 Mac 上快取的 Steam 工作階段。下載前需在終端機重新登入。若要在所有裝置上登出,請在 Steam →設定→安全性 中取消此裝置的授權。"
          }
        }
      }
    },
    "This configuration is for a different app (%@). Expected %@." : {
      "comment" : "Import failure: bundle identifier doesn't match.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This configuration is for a different app (%1$@). Expected %2$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この構成は別のアプリ（%1$@）用です。想定：%2$@。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此配置适用于其他应用（%1$@）。预期为 %2$@。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此設定適用於其他 App（%1$@）。預期為 %2$@。"
          }
        }
      }
    },
    "This configuration was made with a different version (schema %lld). This build supports schema 1 through %lld." : {
      "comment" : "Import failure: schema is outside the supported range.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This configuration was made with a different version (schema %1$lld). This build supports schema 1 through %2$lld."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この構成は別のバージョン（スキーマ %1$lld）で作成されています。このビルドはスキーマ 1 から %2$lld まで対応しています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此配置由其他版本创建（架构 %1$lld）。此版本支持架构 1 到 %2$lld。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
