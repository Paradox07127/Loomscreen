    "Importing replaces the current global preferences, display defaults, and per-display setup. Bookmarks from the backup are merged into your library — existing entries with the same source are kept." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importing replaces the current global preferences, display defaults, and per-display setup. Bookmarks from the backup are merged into your library — existing entries with the same source are kept."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "読み込むと現在のグローバル環境設定、表示デフォルト、ディスプレイごとの設定が置き換わります。バックアップ内のブックマークはライブラリに統合され、同じソースの既存項目は保持されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "导入会替换当前全局偏好、显示默认值和每个显示器的设置。备份中的书签会合并到你的库中；来源相同的现有条目会保留。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "匯入會取代目前全域偏好、顯示預設值和各顯示器設定。備份中的書籤會合併到你的資料庫；來源相同的既有項目會保留。"
          }
        }
      }
    },
