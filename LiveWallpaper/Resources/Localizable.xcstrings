    "Texture format %lld is not in the Phase 2.1 decoder. The renderer skips just this layer; the rest of the scene continues." : {
      "comment" : "Texture fallback warning body. The placeholder is a texture format code.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Texture format %lld is not in the Phase 2.1 decoder. The renderer skips just this layer; the rest of the scene continues."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "テクスチャ形式 %lld は Phase 2.1 デコーダーに含まれていません。レンダラーはこのレイヤーだけをスキップし、シーンの残りは続行されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "纹理格式 %lld 尚未包含在 Phase 2.1 解码器中。渲染器只会跳过该图层，其余场景会继续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "紋理格式 %lld 尚未納入 Phase 2.1 解碼器。算繪器只會略過此圖層；場景的其餘部分會繼續。"
          }
        }
      }
    },
    "Texture format 8 (RGBA1010102) is rare and pending decoder support. Most other layers in this scene should still render." : {
      "comment" : "Texture fallback warning body.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Texture format 8 (RGBA1010102) is rare and pending decoder support. Most other layers in this scene should still render."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "テクスチャ形式 8（RGBA1010102）はまれで、デコーダー対応待ちです。このシーンの他のほとんどのレイヤーは引き続きレンダリングされるはずです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "纹理格式 8（RGBA1010102）较少见，解码支持仍在排期中。此场景中的大多数其他图层应仍可渲染。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
