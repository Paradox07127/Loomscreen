    "New scenes read their assets in place from the source, so this cache only holds older imports. Unreferenced leftovers are reclaimed automatically at startup." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいシーンは元の場所からアセットを直接読み取るため、このキャッシュには古い読み込み分だけが保持されます。参照されていない残りは起動時に自動回収されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新场景会从源位置直接读取资源，因此此缓存只保存较早的导入内容。未引用的残留项会在启动时自动回收。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新場景會從來源位置直接讀取資源，因此此快取只保存較早的匯入內容。未參照的殘留項目會在啟動時自動回收。"
          }
        }
      }
    },
