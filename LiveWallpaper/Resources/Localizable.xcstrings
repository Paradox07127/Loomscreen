        }
      }
    },
    "Lets the scene receive real clicks and drags (for interactive scenes). While on, clicks go to the wallpaper instead of the desktop on this display — you won't be able to click desktop icons until you turn it back off." : {
      "comment" : "Text displayed in a setting row that lets the scene receive real clicks and drags (for interactive scenes). When on, clicks go to the wallpaper instead of the desktop on this display — you won't be able to",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シーンが実際のクリックとドラッグを受け取れるようにします（インタラクティブシーン用）。オンの間、このディスプレイでのクリックはデスクトップではなく壁紙に送られます — オフに戻すまでデスクトップアイコンはクリックできません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让场景接收真实点击和拖拽（用于交互式场景）。开启时，此显示器上的点击会发送到壁纸而不是桌面 — 关闭前将无法点击桌面图标。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讓場景接收真實點按和拖移（用於互動式場景）。開啟時，此顯示器上的點按會傳送到桌布而不是桌面 — 關閉前將無法點按桌面圖示。"
          }
        }
      }
    },
    "Lets wallpapers react to the audio playing on your Mac. Off by default; requires audio-recording permission." : {
