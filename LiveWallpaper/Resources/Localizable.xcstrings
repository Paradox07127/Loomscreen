    "JavaScript runs on this origin. Revoke to disable script execution." : {
      "comment" : "Info tooltip on the Origin Access row when the origin is trusted.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
