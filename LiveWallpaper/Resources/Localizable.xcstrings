          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebGL コンテンツを Retina 解像度でレンダリングし、キャラクターアートや Spine ウォールペーパーがぼやけて見えるのを防ぎます。Wallpaper Engine フォルダでは自動で有効になります。"
          }
