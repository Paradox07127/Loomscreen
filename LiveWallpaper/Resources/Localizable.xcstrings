    "Frames extracted from scene videos, reused across launches. Capped at 2 GB — the least-recently-used files are removed first, and orphaned scenes are reclaimed at startup." : {
      "comment" : "Footer explaining the scene video texture cache bounds.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シーン動画から抽出したフレームを、起動をまたいで再利用します。上限は 2 GB で、最も長く使われていないファイルから削除され、孤立したシーンは起動時に回収されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从场景视频中提取的帧，跨启动复用。上限 2 GB——最久未使用的文件会优先删除，孤立场景会在启动时回收。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從場景影片中擷取的影格，跨啟動重複使用。上限 2 GB——最久未使用的檔案會優先刪除，孤立場景會在啟動時回收。"
          }
        }
      }
    },
    "Freed %@." : {
      "comment" : "WPE cache management footer shown after a purge. Placeholder is the freed byte total, rendered through SwiftUI's byteCount format style.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
