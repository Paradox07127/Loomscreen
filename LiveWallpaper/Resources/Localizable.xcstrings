    "Renders CSS-naive HTML canvas content at retina resolution. Auto-enabled only for imported project folders that do not already use devicePixelRatio." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renders CSS-naive HTML canvas content at retina resolution. Auto-enabled only for imported project folders that do not already use devicePixelRatio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CSS ピクセル前提の HTML canvas コンテンツを Retina 解像度でレンダリングします。devicePixelRatio をまだ使っていないインポート済みプロジェクトフォルダでのみ自動で有効になります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以 Retina 分辨率渲染不处理 DPR 的 HTML canvas 内容。仅对尚未使用 devicePixelRatio 的已导入项目文件夹自动启用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以 Retina 解析度算繪未處理 DPR 的 HTML canvas 內容。僅對尚未使用 devicePixelRatio 的已匯入專案資料夾自動啟用。"
          }
        }
      }
    },
