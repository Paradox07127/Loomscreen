    "Auto-detect finds a Homebrew or tarball install; otherwise pick SteamCMD's executable or its `steamcmd.sh` wrapper." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動検出では Homebrew または tarball インストールを探します。見つからない場合は SteamCMD の実行ファイルまたは `steamcmd.sh` ラッパーを選択してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
