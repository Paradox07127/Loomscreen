          }
        }
      }
    },
    "The bundle includes global preferences, display defaults, wallpaper library bookmarks, and per-display playback / effect setup. Wallpaper files themselves are not copied — only references to them." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The bundle includes global preferences, display defaults, wallpaper library bookmarks, and per-display playback / effect setup. Wallpaper files themselves are not copied — only references to them."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バンドルにはグローバル環境設定、表示デフォルト、壁紙ライブラリのブックマーク、ディスプレイごとの再生/エフェクト設定が含まれます。壁紙ファイル自体はコピーされず、参照だけが保存されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "备份包含全局偏好、显示默认值、壁纸库书签，以及每个显示器的播放/效果设置。壁纸文件本身不会被复制，只会保存引用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "備份包含全域偏好、顯示預設值、桌布資料庫書籤，以及各顯示器的播放/效果設定。桌布檔案本身不會被複製，只會儲存引用。"
          }
        }
      }
    },
    "The download timed out. Try again." : {
      "comment" : "Engine-assets download timed out.\nWorkshop download timed out.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
