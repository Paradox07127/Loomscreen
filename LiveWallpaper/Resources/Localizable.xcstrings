    "You already have a statusLine command. It has been placed after the LiveWallpaper script above so it keeps running — merge this block into ~/.claude/settings.json." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すでに statusLine コマンドが設定されています。上の LiveWallpaper スクリプトの後に連結してあるため、そのまま動き続けます。このブロックを ~/.claude/settings.json にマージしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经有一个 statusLine 命令。它已被排在上面 LiveWallpaper 脚本之后以继续生效——把这个配置块合并进 ~/.claude/settings.json 即可。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
