    "Backup & Restore" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup & Restore"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バックアップと復元"
          }
        },
        "zh-Hans" : {
