    "Caps below 30 FPS force a compositing pass — useful when effects are active or to extend battery on long sessions. 60 FPS and Unlimited use the native playback path." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caps below 30 FPS force a compositing pass — useful when effects are active or to extend battery on long sessions. 60 FPS and Unlimited use the native playback path."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 FPS 以下に制限するとコンポジションパスを強制します — エフェクトを使う場合や長時間の利用時にバッテリーを延ばすのに有効です。60 FPS と Unlimited はネイティブ再生パスを使います。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "低于 30 FPS 的限制会强制走合成通路——在启用了滤镜或长时间运行需要延长续航时有用。60 FPS 和 Unlimited 使用原生播放通路。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "低於 30 FPS 的限制會強制走合成通路——在啟用了濾鏡或長時間執行需要延長續航時有用。60 FPS 和 Unlimited 使用原生播放通路。"
          }
        }
      }
    },
    "Caps decode at 1080p / 8 Mbps to lighten GPU load." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caps decode at 1080p / 8 Mbps to lighten GPU load."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPU 負荷を軽減するため、デコードを 1080p / 8 Mbps に制限します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将解码上限设为 1080p / 8 Mbps，减轻 GPU 负担。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將解碼上限設為 1080p / 8 Mbps，以降低 GPU 負載。"
          }
        }
      }
    },
    "Caps playback at 1080p / 8 Mbps. Looks identical on a 1080p display; lower GPU draw, longer battery life." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caps playback at 1080p / 8 Mbps. Looks identical on a 1080p display; lower GPU draw, longer battery life."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再生を 1080p / 8 Mbps に制限します。1080p ディスプレイなら見た目は同じで、GPU 負荷とバッテリー消費を抑えられます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把播放限制到 1080p / 8 Mbps。在 1080p 显示器上视觉一致，GPU 占用更低，电池更耐用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將播放限制到 1080p / 8 Mbps。在 1080p 顯示器上視覺一致，GPU 佔用更低，電池更耐用。"
          }
        }
      }
    },
