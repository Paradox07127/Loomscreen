    "Higher = fewer disk reads, more RAM. Lower = less RAM, video re-reads disk on every loop." : {
      "comment" : "Tooltip for the video memory cache slider.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Higher = fewer disk reads, more RAM. Lower = less RAM, video re-reads disk on every loop."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高くするとディスク読み取りが減り、RAM 使用量が増えます。低くすると RAM 使用量は減りますが、動画はループごとにディスクを再読み込みします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数值越高，磁盘读取越少、内存占用越多；数值越低，内存占用越少，但每次循环都会重新读取磁盘。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "數值越高，磁碟讀取越少、記憶體用量越多。數值越低，記憶體用量越少，但影片每次循環都會重新讀取磁碟。"
          }
        }
      }
    },
