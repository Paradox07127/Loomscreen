    "\nYou may need to reconfigure these screens." : {
      "comment" : "Validation follow-up guidance.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nYou may need to reconfigure these screens."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nこれらの画面を再設定する必要がある場合があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可能需要重新配置这些屏幕。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n您可能需要重新設定這些螢幕。"
          }
        }
      }
    },
    "· %lld-core GPU" : {
      "comment" : "GPU identity: core count.",
