    },
    "This file is too large to import (%lld bytes). Configuration backups are usually well under 10 MB." : {
      "comment" : "Import failure: the file exceeds the size cap and is likely not a real config bundle.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This file is too large to import (%lld bytes). Configuration backups are usually well under 10 MB."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このファイルは大きすぎてインポートできません（%lld バイト）。構成バックアップは通常 10 MB を大きく下回ります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此文件太大，无法导入（%lld 字节）。配置备份通常远小于 10 MB。"
