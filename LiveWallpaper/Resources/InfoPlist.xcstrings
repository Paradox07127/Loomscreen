    "NSDesktopFolderUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access to Desktop is needed to play wallpaper files stored there."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デスクトップに保存されている壁紙ファイルを再生するために、デスクトップへのアクセスが必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要访问桌面以播放存储在其中的壁纸文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要存取桌面，才能播放儲存在其中的桌布檔案。"
          }
        }
      }
    },
    "NSDocumentsFolderUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access to Documents is needed to play wallpaper files stored there."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "書類に保存されている壁紙ファイルを再生するために、書類へのアクセスが必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要访问文稿以播放存储在其中的壁纸文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要存取文件，才能播放儲存在其中的桌布檔案。"
          }
        }
      }
    },
    "NSDownloadsFolderUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access to Downloads is needed to play wallpaper files stored there."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダウンロードに保存されている壁紙ファイルを再生するために、ダウンロードへのアクセスが必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要访问下载以播放存储在其中的壁纸文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要存取下載項目，才能播放儲存在其中的桌布檔案。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location is used to fetch local weather for weather-reactive effects."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報は、天気に反応するエフェクト用にローカルの天気を取得するために使われます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "定位用于获取本地天气，以驱动随天气变化的效果。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置資訊用來取得本地天氣，驅動會隨天氣變化的效果。"
          }
        }
      }
    }
  },
  "version" : "1.0"
